<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <title>SyncText</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'brand': '#2196f3',
                        'surface': '#f3f3f3',
                        'soft-border': 'rgba(0, 0, 0, 0.17)',
                    },
                    fontFamily: {
                        sans: ['"Inter"', 'sans-serif'],
                    },

                    borderRadius: {
                        '3xl': '30px',
                    },
                    boxShadow: {
                        'premium': '0 20px 60px rgba(0, 0, 0, 0.15)',
                        'inner-soft': 'inset 0 2px 4px 0 rgba(0, 0, 0, 0.03)',
                    },
                    animation: {
                        'float': 'fadeIn 0.3s ease-out',
                    },
                }
            }
        }
    </script>
    <style>
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .spinner {
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top: 2px solid #ffffff;
            width: 14px;
            height: 14px;
            animation: spin 0.8s linear infinite;
            display: none;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        @keyframes typing {

            0%,
            60%,
            100% {
                transform: translateY(0);
            }

            30% {
                transform: translateY(-3px);
            }
        }

        .btn.loading .spinner {
            display: inline-block;
        }

        .btn.loading .btn-text {
            display: none;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.2);
        }

        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }
    </style>
</head>

<body
    class="bg-[#f0f0f0] dark:bg-zinc-950 text-black dark:text-white antialiased tracking-tight transition-colors duration-300">
    <header id="globalHeader"
        class="fixed top-0 left-0 right-0 z-[150] flex justify-center p-6 pointer-events-none transition-all duration-300">
        <div class="flex items-center gap-2 pointer-events-auto">
            <div
                class="flex items-center gap-4 text-[12px] font-normal uppercase tracking-widest text-black dark:text-white leading-none bg-[#ffffff] dark:bg-[#18181b] px-5 py-2 rounded-full border border-black/5 dark:border-white/5">
                <div class="flex items-center gap-1.5">
                    <span class="text-black dark:text-white font-black" id="activeTodayCount">0</span>
                    <span>Active</span>
                </div>
                <span class="text-black dark:text-white">•</span>
                <div class="flex items-center gap-1.5">
                    <span class="text-black dark:text-white font-black" id="totalUsersCount">0</span>
                    <span>Total Users</span>
                </div>
            </div>
            <button id="darkModeToggleHeader"
                class="h-8 px-3 rounded-full bg-white dark:bg-[#18181b] border border-black/5 dark:border-white/5 flex items-center gap-2 text-black dark:text-white hover:bg-gray-100 dark:hover:bg-white/10 transition-all">
                <div class="relative w-4 h-4">
                    <svg class="w-4 h-4 absolute inset-0 transition-opacity duration-300 block dark:hidden"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                    <svg class="w-4 h-4 absolute inset-0 transition-opacity duration-300 hidden dark:block"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Mode</span>
            </button>
        </div>
    </header>

    <div class="min-h-screen flex items-center justify-center p-4 md:p-6">
        <div id="joinScreen"
            class="w-full max-w-[380px] bg-white dark:bg-zinc-900 border border-soft-border dark:border-white/5 rounded-3xl p-4 shadow-premium flex flex-col items-center text-center relative animate-float">
            <div class="w-full flex justify-between items-center mb-4">
                <div class="flex items-center gap-2">
                    <div class="relative group">
                        <button
                            class="w-8 h-8 rounded-full bg-surface dark:bg-white/5 border border-black/10 dark:border-white/10 flex items-center justify-center transition-all hover:bg-gray-200 dark:hover:bg-white/10"
                            id="infoBtn">
                            <svg class="w-4 h-4 text-black dark:text-white" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="12" y1="8" x2="12" y2="8"></line>
                                <line x1="12" y1="12" x2="12" y2="16"></line>
                            </svg>
                        </button>
                        <div class="absolute top-10 left-0 w-[260px] bg-white dark:bg-zinc-800 border border-black/10 dark:border-white/10 rounded-2xl p-5 text-left shadow-[0_20px_40px_rgba(0,0,0,0.12)] z-20 hidden [&.active]:block animate-float"
                            id="infoPopup">
                            <h3
                                class="text-[11px] font-black uppercase tracking-[0.15em] mb-4 flex items-center gap-2 dark:text-white">
                                <span class="w-1.5 h-1.5 rounded-full bg-brand"></span>
                                App Details
                            </h3>
                            <div
                                class="text-[11px] font-medium text-black/60 dark:text-white/60 space-y-3 leading-relaxed">
                                <p>
                                    Created by: <b class="text-black dark:text-white">Prince Vic Lacson Mayordo</b><br>
                                    App: <b class="text-black dark:text-white">SyncText</b><br>
                                    Version: <span class="text-black dark:text-white">1.0</span>
                                </p>
                                <p class="pt-3 border-t border-black/5 dark:border-white/5 opacity-80 italic">
                                    A simple app for real-time text collaboration.<br>
                                    Join a room. Type together. Sync instantly.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <button
                    class="h-8 px-3 rounded-full bg-surface dark:bg-white/5 border border-black/10 dark:border-white/10 text-[10px] font-bold uppercase tracking-wider flex items-center gap-1.5 hover:bg-gray-200 dark:hover:bg-white/10 dark:text-white transition-all shadow-sm"
                    id="feedbackBtn">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                    Feedback
                </button>
            </div>

            <div class="mb-8 text-center space-y-2">
                <h1 class="text-[28px] font-black tracking-tighter text-black dark:text-white leading-tight">SyncText
                </h1>
                <p class="text-[13px] font-bold text-black/40 dark:text-white/30 leading-relaxed">
                    Sync text instantly across devices. Fast and secure.
                </p>
                <div class="pt-1">
                    <p
                        class="text-[10px] font-black text-black dark:text-white leading-relaxed uppercase tracking-[0.25em]">
                        Type • Edit • Sync
                    </p>
                </div>
            </div>

            <div
                class="w-full bg-surface dark:bg-zinc-800/50 border border-black/5 dark:border-white/5 rounded-2xl p-3.5 mb-3.5">
                <form id="joinForm" class="flex flex-col gap-2.5">
                    <div class="flex flex-col items-center">
                        <label for="pinInput"
                            class="text-[9px] uppercase tracking-[0.2em] font-bold opacity-40 dark:text-white mb-2.5">Enter
                            Room PIN</label>
                        <input type="text" id="pinInput" maxlength="6" placeholder="000000"
                            class="w-full bg-[#fdfdfd] dark:bg-zinc-800 border border-black/[0.06] dark:border-white/10 rounded-xl py-2 px-4 text-center text-xl font-bold tracking-[0.5em] outline-none transition-all focus:border-brand focus:ring-4 focus:ring-brand/5 shadow-inner-soft dark:text-white dark:placeholder:text-white/10">
                    </div>
                    <button type="submit"
                        class="w-full h-9 bg-black text-white rounded-xl text-[11px] font-bold uppercase tracking-widest hover:bg-black/90 transition-all flex items-center justify-center gap-2 active:scale-[0.98]"
                        id="joinBtn">
                        <span class="btn-text">Join Room</span>
                        <div class="spinner"></div>
                    </button>
                    <div class="flex items-center gap-1.5 my-0.5">
                        <div class="flex-1 h-[1px] bg-black/5"></div>
                        <span class="text-[9px] uppercase font-bold opacity-30">or</span>
                        <div class="flex-1 h-[1px] bg-black/5"></div>
                    </div>
                    <button type="button"
                        class="w-full h-9 bg-brand text-white rounded-xl text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all flex items-center justify-center gap-2 active:scale-[0.98]"
                        id="createBtn">
                        <span class="btn-text">Create Room</span>
                        <div class="spinner"></div>
                    </button>
                </form>
            </div>
            <p
                class="text-[9px] text-black/50 dark:text-white/30 font-medium tracking-wide text-center leading-relaxed max-w-[280px] mx-auto">
                <b class="text-black dark:text-white">Privacy:</b> Rooms are automatically deleted when the last user
                leaves, and no data is stored after the session ends.
            </p>
        </div>

        <div id="editorScreen"
            class="w-full max-w-[950px] bg-white dark:bg-zinc-900 border border-black/5 dark:border-white/5 rounded-3xl shadow-premium flex flex-col max-h-[90vh] overflow-hidden animate-float hidden">
            <div class="p-5 pb-4 border-b border-black/5 dark:border-white/5 flex flex-col gap-3">
                <div class="flex justify-between items-center relative">
                    <button
                        class="bg-surface dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-full px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider cursor-pointer flex items-center gap-1.5 transition-all hover:bg-gray-200 dark:hover:bg-white/10 dark:text-white"
                        id="homeBtn">
                        <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <path d="M3 9.5L12 3l9 6.5M5.5 8.5V20a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1V8.5" />
                        </svg>
                        Home
                    </button>

                    <h2
                        class="text-[18px] font-black tracking-tighter text-black dark:text-white leading-tight absolute left-1/2 -translate-x-1/2 whitespace-nowrap">
                        SyncText Room</h2>

                    <div class="flex items-center gap-2">
                        <div
                            class="bg-black/[0.03] dark:bg-white/[0.03] border border-black/5 dark:border-white/5 px-3 py-1.5 rounded-full flex items-center gap-2">
                            <span id="pinDisplay"
                                class="text-[11px] font-black tracking-[3px] text-black dark:text-white leading-none">000000</span>
                            <button
                                class="bg-transparent border-none p-0 cursor-pointer text-black/30 dark:text-white/30 hover:text-brand transition-colors"
                                id="copyBtn">
                                <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="3">
                                    <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                                    <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"></path>
                                </svg>
                            </button>
                        </div>
                        <button id="darkModeToggleEditor"
                            class="h-7 w-7 rounded-full bg-black/[0.03] dark:bg-white/[0.03] border border-black/5 dark:border-white/5 flex items-center justify-center text-black dark:text-white hover:bg-gray-100 dark:hover:bg-white/10 transition-all">
                            <svg class="w-3.5 h-3.5 block dark:hidden" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="3">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                            </svg>
                            <svg class="w-3.5 h-3.5 hidden dark:block" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="3">
                                <circle cx="12" cy="12" r="5"></circle>
                                <path
                                    d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex flex-col md:flex-row overflow-hidden">
                <div class="flex-1 border-r border-black/5 dark:border-white/5 flex flex-col relative">
                    <textarea id="textEditor"
                        class="flex-1 w-full bg-white dark:bg-zinc-900 border-none p-6 pb-20 font-sans text-[14px] leading-relaxed resize-none text-black dark:text-white outline-none placeholder:text-black/20 dark:placeholder:text-white/10"
                        placeholder="Start typing... Your changes will be synced in realtime."
                        spellcheck="true"></textarea>

                    <div class="absolute bottom-6 left-6 bg-surface dark:bg-zinc-800 border border-black/10 dark:border-white/10 rounded-full px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider text-black dark:text-white flex items-center gap-1.5 opacity-0 translate-y-2 transition-all duration-300 pointer-events-none z-10 [&.active]:opacity-100 [&.active]:translate-y-0"
                        id="typingIndicator">
                        <div class="flex gap-0.5">
                            <div
                                class="w-[3px] h-[3px] rounded-full bg-black dark:bg-white animate-[typing_1.4s_infinite]">
                            </div>
                            <div
                                class="w-[3px] h-[3px] rounded-full bg-black dark:bg-white animate-[typing_1.4s_infinite_0.2s]">
                            </div>
                            <div
                                class="w-[3px] h-[3px] rounded-full bg-black dark:bg-white animate-[typing_1.4s_infinite_0.4s]">
                            </div>
                        </div>
                        <span>Syncing Changes...</span>
                    </div>

                    <div class="absolute bottom-6 right-6 flex items-center gap-2">
                        <span id="copyBtnText"
                            class="text-[9px] font-black uppercase tracking-widest text-brand opacity-0 transition-opacity">Copied!</span>
                    </div>
                </div>

                <div class="w-full md:w-[280px] bg-surface dark:bg-black/20 flex flex-col overflow-y-auto">
                    <div class="p-5 flex flex-col gap-6">
                        <div class="flex flex-col gap-3">
                            <div
                                class="text-[9px] font-black uppercase tracking-[0.15em] text-black/40 dark:text-white/30">
                                Room Experience</div>
                            <div
                                class="bg-white dark:bg-zinc-900 border border-black/5 dark:border-white/5 rounded-2xl p-4 flex flex-col gap-4">
                                <div class="flex items-center justify-between">
                                    <span class="text-[10px] font-bold text-black/60 dark:text-white/40">Network
                                        Status</span>
                                    <div class="flex items-center gap-1.5 bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20"
                                        id="roomStatusGroup">
                                        <div class="w-1.5 h-1.5 rounded-full bg-green-500 [&.disconnected]:bg-red-500"
                                            id="statusDot"></div>
                                        <span id="statusText"
                                            class="text-[9px] font-black uppercase tracking-widest text-green-500">Live</span>
                                    </div>
                                </div>

                                <div class="h-[1px] bg-black/5 dark:bg-white/5"></div>

                                <div class="flex flex-col gap-3" id="activeUsersList">
                                    <span class="text-[10px] font-bold text-black/60 dark:text-white/40"
                                        id="userCount">0 Users Joined</span>
                                    <div class="flex items-center -space-x-2 overflow-hidden" id="userPresenceAvatars">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-3">
                            <p
                                class="text-[10px] text-black/50 dark:text-white/30 font-medium leading-relaxed bg-white/40 dark:bg-white/[0.02] p-3 rounded-xl border border-black/5 dark:border-white/5">
                                <b class="text-black dark:text-white">Privacy:</b> This room is automatically deleted
                                when the last user leaves, and no data is stored after the session ends.
                            </p>
                        </div>

                        <div class="mt-4 pt-4 border-t border-black/5 dark:border-white/5 flex justify-center">
                            <button
                                class="bg-red-500/10 text-red-500 border-none rounded-full px-5 py-2 text-[9px] font-black uppercase tracking-[0.2em] cursor-pointer transition-all hover:bg-red-500/20 active:scale-95 flex items-center gap-2"
                                id="leaveBtn">
                                <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="3">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" />
                                </svg>
                                Leave Room
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="feedbackScreen"
            class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/5 dark:bg-black/60 backdrop-blur-md hidden animate-float">
            <div
                class="w-full max-w-[850px] bg-white dark:bg-zinc-900 border border-black/5 dark:border-white/5 rounded-3xl shadow-premium flex flex-col max-h-[90vh] overflow-hidden">
                <div class="p-5 pb-4 border-b border-black/5 dark:border-white/5 flex flex-col gap-3">
                    <div class="flex justify-between items-center relative">
                        <button
                            class="bg-surface dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-full px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider cursor-pointer flex items-center gap-1.5 transition-all hover:bg-gray-200 dark:hover:bg-white/10 dark:text-white"
                            id="feedbackHomeBtn">
                            <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="3">
                                <path d="M18 6L6 18M6 6l12 12"></path>
                            </svg>
                            Close
                        </button>

                        <h2
                            class="text-[18px] font-black tracking-tighter text-black dark:text-white leading-tight absolute left-1/2 -translate-x-1/2 whitespace-nowrap">
                            SyncText Community</h2>

                        <div class="flex items-center gap-2">
                            <div id="feedbackAuthUser"
                                class="hidden items-center gap-2 bg-black/[0.03] dark:bg-white/[0.03] border border-black/5 dark:border-white/5 pl-1.5 pr-2.5 py-1 rounded-full">
                            </div>
                            <button
                                class="bg-black dark:bg-white dark:text-black text-white border-none rounded-full px-3 py-1.5 text-[9px] font-bold uppercase tracking-widest cursor-pointer transition-all hover:opacity-80"
                                id="googleLoginBtn">Google Login</button>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col md:flex-row flex-1 overflow-hidden">
                    <div
                        class="flex-1 overflow-y-auto p-5 border-r border-black/5 dark:border-white/5 bg-gray-50/30 dark:bg-black/10">
                        <div id="feedbackList" class="flex flex-col gap-3 pr-1 scroll-smooth"></div>
                    </div>

                    <div class="w-full md:w-[340px] p-5 flex flex-col gap-6 bg-white dark:bg-zinc-900 overflow-y-auto">
                        <div class="flex flex-col gap-4">
                            <div class="flex flex-col gap-1">
                                <span
                                    class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/20">Write
                                    Feedback</span>
                                <p class="text-[11px] font-bold text-black/40 dark:text-white/30">Share your experience
                                    with SyncText.</p>
                            </div>

                            <div
                                class="bg-surface dark:bg-zinc-800/40 border border-black/5 dark:border-white/5 rounded-2xl p-4 flex flex-col gap-4">
                                <div class="flex justify-center gap-2" id="ratingRow">
                                    <button type="button"
                                        class="star-btn bg-none border-none text-[24px] cursor-pointer text-[#d1d1d1] transition-all hover:scale-125 leading-none px-0 [&.active]:text-[#ffc107]"
                                        data-rating="1">★</button>
                                    <button type="button"
                                        class="star-btn bg-none border-none text-[24px] cursor-pointer text-[#d1d1d1] transition-all hover:scale-125 leading-none px-0 [&.active]:text-[#ffc107]"
                                        data-rating="2">★</button>
                                    <button type="button"
                                        class="star-btn bg-none border-none text-[24px] cursor-pointer text-[#d1d1d1] transition-all hover:scale-125 leading-none px-0 [&.active]:text-[#ffc107]"
                                        data-rating="3">★</button>
                                    <button type="button"
                                        class="star-btn bg-none border-none text-[24px] cursor-pointer text-[#d1d1d1] transition-all hover:scale-125 leading-none px-0 [&.active]:text-[#ffc107]"
                                        data-rating="4">★</button>
                                    <button type="button"
                                        class="star-btn bg-none border-none text-[24px] cursor-pointer text-[#d1d1d1] transition-all hover:scale-125 leading-none px-0 [&.active]:text-[#ffc107]"
                                        data-rating="5">★</button>
                                </div>
                                <textarea id="feedbackInput"
                                    class="w-full min-h-[100px] p-3.5 bg-white dark:bg-[#18181b] border border-black/[0.06] dark:border-white/10 rounded-xl font-sans text-[13px] leading-relaxed resize-none outline-none transition-all focus:border-brand dark:text-white dark:placeholder:text-white/20"
                                    placeholder="What's on your mind?"></textarea>

                                <div class="flex flex-col gap-3 items-center">
                                    <button id="sendFeedbackBtn"
                                        class="w-full h-10 bg-black dark:bg-white text-white dark:text-black rounded-xl text-[11px] font-bold uppercase tracking-widest cursor-pointer transition-all hover:opacity-90 active:scale-[0.98]">Post
                                        Feedback</button>
                                    <button id="deleteFeedbackBtn"
                                        class="hidden bg-red-500/10 text-red-500 px-4 py-1.5 rounded-full text-[8px] font-black uppercase tracking-widest transition-all hover:bg-red-500/20 active:scale-95 mx-auto">Delete
                                        My Feedback</button>
                                </div>
                                <div id="feedbackAuthNote"
                                    class="text-center text-[9px] font-bold uppercase tracking-widest opacity-30 dark:text-white/40">
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-4 pt-4 border-t border-black/5 dark:border-white/5">
                            <span
                                class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/20">Community
                                Sentiment</span>
                            <div class="flex flex-col gap-2">
                                <div class="flex items-center gap-3">
                                    <span class="text-[9px] font-black w-4">5★</span>
                                    <div
                                        class="flex-1 h-1.5 bg-black/[0.03] dark:bg-white/[0.03] rounded-full overflow-hidden">
                                        <div class="h-full bg-[#ffc107] rounded-full" style="width: 85%"></div>
                                    </div>
                                    <span class="text-[9px] font-bold opacity-30">85%</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="text-[9px] font-black w-4">4★</span>
                                    <div
                                        class="flex-1 h-1.5 bg-black/[0.03] dark:bg-white/[0.03] rounded-full overflow-hidden">
                                        <div class="h-full bg-[#ffc107]/60 rounded-full" style="width: 12%"></div>
                                    </div>
                                    <span class="text-[9px] font-bold opacity-30">12%</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="text-[9px] font-black w-4">3★</span>
                                    <div
                                        class="flex-1 h-1.5 bg-black/[0.03] dark:bg-white/[0.03] rounded-full overflow-hidden">
                                        <div class="h-full bg-black/20 rounded-full" style="width: 2%"></div>
                                    </div>
                                    <span class="text-[9px] font-bold opacity-30">2%</span>
                                </div>
                                <div class="flex items-center gap-3 opacity-30">
                                    <span class="text-[9px] font-black w-4">1★</span>
                                    <div
                                        class="flex-1 h-1.5 bg-black/[0.03] dark:bg-white/[0.03] rounded-full overflow-hidden">
                                        <div class="h-full bg-black/20 rounded-full" style="width: 1%"></div>
                                    </div>
                                    <span class="text-[9px] font-bold">1%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <script type="module">
        const toggleTheme = () => {
            document.documentElement.classList.toggle('dark');
            const isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('syncTextTheme', isDark ? 'dark' : 'light');
        };

        const headerToggle = document.getElementById('darkModeToggleHeader');
        const editorToggle = document.getElementById('darkModeToggleEditor');

        if (headerToggle) headerToggle.addEventListener('click', toggleTheme);
        if (editorToggle) editorToggle.addEventListener('click', toggleTheme);
        const globalHeader = document.getElementById('globalHeader');
        function updateHeaderVisibility(screen) {
            if (screen === 'join') {
                globalHeader.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-10');
            } else {
                globalHeader.classList.add('opacity-0', 'pointer-events-none', '-translate-y-10');
            }
        }
        if (localStorage.getItem('syncTextTheme') === 'dark' ||
            (!localStorage.getItem('syncTextTheme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
        const FIREBASE_CONFIG = {
            apiKey: "AIzaSyBiJAsJF15DZ56tels2Lgen89xKPoFkgUY",
            authDomain: "pvlm-app.firebaseapp.com",
            projectId: "pvlm-app",
            storageBucket: "pvlm-app.appspot.com",
            messagingSenderId: "946963419847",
            appId: "1:946963419847:web:02ae6c34035702b2b224e2",
            databaseURL: "https://pvlm-app-default-rtdb.firebaseio.com"
        };
        import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
        import {
            getDatabase,
            ref,
            set,
            get,
            remove,
            onValue,
            onDisconnect,
            runTransaction,
        } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js';
        import {
            getAuth,
            GoogleAuthProvider,
            signInWithPopup,
            signInWithRedirect,
            getRedirectResult,
            onAuthStateChanged,
            signOut,
        } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js';
        const app = initializeApp(FIREBASE_CONFIG);
        const database = getDatabase(app);
        const auth = getAuth(app);
        const googleProvider = new GoogleAuthProvider();
        const ADMIN_EMAIL = 'pvlm.contact@gmail.com';
        const state = {
            currentRoom: null,
            currentPin: null,
            userId: generateUserId(),
            isConnected: true,
            typingTimeout: null,
            isTyping: false,
            lastSyncTime: 0,
            syncDebounceTimer: null,
            isApplyingRemoteText: false,
            visitorKey: null,
        };
        const joinScreen = document.getElementById('joinScreen');
        const editorScreen = document.getElementById('editorScreen');
        const feedbackScreen = document.getElementById('feedbackScreen');
        const pinInput = document.getElementById('pinInput');
        const joinBtn = document.getElementById('joinBtn');
        const createBtn = document.getElementById('createBtn');
        const pinDisplay = document.getElementById('pinDisplay');
        const copyBtn = document.getElementById('copyBtn');
        const copyBtnText = document.getElementById('copyBtnText');
        const statusDot = document.getElementById('statusDot');
        const statusText = document.getElementById('statusText');
        const userCount = document.getElementById('userCount');
        const textEditor = document.getElementById('textEditor');
        const typingIndicator = document.getElementById('typingIndicator');
        const homeBtn = document.getElementById('homeBtn');
        const leaveBtn = document.getElementById('leaveBtn');
        const joinForm = document.getElementById('joinForm');
        const activeTodayCount = document.getElementById('activeTodayCount');
        const totalUsersCount = document.getElementById('totalUsersCount');
        const infoBtn = document.getElementById('infoBtn');
        const infoPopup = document.getElementById('infoPopup');
        const feedbackBtn = document.getElementById('feedbackBtn');
        const feedbackHomeBtn = document.getElementById('feedbackHomeBtn');
        const feedbackAuthUser = document.getElementById('feedbackAuthUser');
        const googleLoginBtn = document.getElementById('googleLoginBtn');
        const feedbackInput = document.getElementById('feedbackInput');
        const sendFeedbackBtn = document.getElementById('sendFeedbackBtn');
        const feedbackList = document.getElementById('feedbackList');
        const feedbackAuthNote = document.getElementById('feedbackAuthNote');
        const deleteFeedbackBtn = document.getElementById('deleteFeedbackBtn');
        const ratingRow = document.getElementById('ratingRow');
        const starButtons = Array.from(document.querySelectorAll('.star-btn'));
        let feedbackRowsCache = [];

        let feedbackListUnsubscribe = null;
        let selectedRating = 0;

        function isAdminUser(user) {
            return !!user?.email && user.email.toLowerCase() === ADMIN_EMAIL;
        }

        function trackTotalUsers() {
            const totalUsersRef = ref(database, 'stats/totalUsersByIp');

            onValue(totalUsersRef, (snapshot) => {
                const users = snapshot.val() || {};
                const count = Object.keys(users).length;
                totalUsersCount.textContent = count;
            });
        }

        function trackActiveToday() {
            const today = new Date().toISOString().split('T')[0];
            const activeTodayRef = ref(database, `stats/activeTodayByIp/${today}`);

            onValue(activeTodayRef, (snapshot) => {
                const users = snapshot.val() || {};
                activeTodayCount.textContent = Object.keys(users).length;
            });
        }

        async function initializeVisitorKey() {
            try {
                const res = await fetch('https://api.ipify.org?format=json');
                const data = await res.json();
                const ip = (data && data.ip ? data.ip : '').trim();
                if (ip) {
                    state.visitorKey = ip.replace(/\./g, '_').replace(/:/g, '_');
                    return;
                }
            } catch (error) {
                console.warn('IP fetch failed, using local fallback:', error);
            }

            let localVisitorKey = localStorage.getItem('visitorKey');
            if (!localVisitorKey) {
                localVisitorKey = `local_${Math.random().toString(36).slice(2, 10)}`;
                localStorage.setItem('visitorKey', localVisitorKey);
            }
            state.visitorKey = localVisitorKey;
        }

        async function trackUserByIp(timestamp) {
            if (!state.visitorKey) {
                await initializeVisitorKey();
            }
            if (!state.visitorKey) return;

            const totalUserRef = ref(database, `stats/totalUsersByIp/${state.visitorKey}`);
            await set(totalUserRef, { lastSeenAt: timestamp });
        }

        async function setupWebsitePresence() {
            if (!state.visitorKey) {
                await initializeVisitorKey();
            }
            if (!state.visitorKey) return;

            const timestamp = Date.now();
            const today = new Date(timestamp).toISOString().split('T')[0];

            const activeTodayRef = ref(database, `stats/activeTodayByIp/${today}/${state.visitorKey}`);
            await set(activeTodayRef, { lastSeenAt: timestamp });

            const onlineRef = ref(database, `stats/onlineUsersByIp/${state.visitorKey}`);
            await set(onlineRef, { lastSeenAt: timestamp });
            await onDisconnect(onlineRef).remove();
        }
        function generateUserId() {
            return 'user_' + Math.random().toString(36).substr(2, 9);
        }

        function generatePin() {
            return Math.floor(100000 + Math.random() * 900000).toString();
        }

        function formatUserCount(count) {
            return count === 1 ? '1 user' : `${count} users`;
        }
        async function createRoom() {
            try {
                createBtn.disabled = true;
                createBtn.classList.add('loading');

                const pin = generatePin();
                const roomRef = ref(database, `rooms/${pin}`);
                const timestamp = Date.now();

                await set(roomRef, {
                    createdAt: timestamp,
                    text: '',
                    users: {
                        [state.userId]: {
                            id: state.userId,
                            joinedAt: timestamp,
                            isTyping: false,
                        },
                    },
                });
                await trackUserByIp(timestamp);

                joinRoom(pin);
            } catch (error) {
                console.error('Error creating room:', error);
                alert('Failed to create room. Please try again.');
            } finally {
                createBtn.disabled = false;
                createBtn.classList.remove('loading');
            }
        }

        async function joinRoom(pin) {
            try {
                joinBtn.disabled = true;
                joinBtn.classList.add('loading');

                const roomRef = ref(database, `rooms/${pin}`);
                const snapshot = await get(roomRef);

                if (!snapshot.exists()) {
                    alert('Room not found. Please check the PIN and try again.');
                    joinBtn.disabled = false;
                    joinBtn.classList.remove('loading');
                    return;
                }

                state.currentRoom = pin;
                state.currentPin = pin;
                const timestamp = Date.now();
                const userRef = ref(database, `rooms/${pin}/users/${state.userId}`);
                await set(userRef, {
                    id: state.userId,
                    joinedAt: timestamp,
                    isTyping: false,
                });
                await onDisconnect(userRef).remove();
                await trackUserByIp(timestamp);
                showEditorScreen();
                setupRoomListeners(pin);
                const textSnapshot = await get(ref(database, `rooms/${pin}/text`));
                if (textSnapshot.exists()) {
                    textEditor.value = textSnapshot.val();
                }
                setTimeout(() => textEditor.focus(), 100);
            } catch (error) {
                console.error('Error joining room:', error);
                alert('Failed to join room. Please try again.');
            } finally {
                joinBtn.disabled = false;
                joinBtn.classList.remove('loading');
            }
        }

        function setupRoomListeners(pin) {
            const textRef = ref(database, `rooms/${pin}/text`);
            onValue(textRef, (snapshot) => {
                const newText = snapshot.val() || '';
                if (newText !== textEditor.value) {
                    state.isApplyingRemoteText = true;
                    textEditor.value = newText;
                    state.isApplyingRemoteText = false;
                }
            });
            const usersRef = ref(database, `rooms/${pin}/users`);
            onValue(usersRef, (snapshot) => {
                const users = snapshot.val() || {};
                const userList = Object.values(users);
                userCount.textContent = `Entered room ${formatUserCount(userList.length)}`;
                const someoneTyping = userList.some(u => u.id !== state.userId && u.isTyping);
                if (someoneTyping) {
                    typingIndicator.classList.add('active');
                } else {
                    typingIndicator.classList.remove('active');
                }
            });
            const connectedRef = ref(database, '.info/connected');
            onValue(connectedRef, (snapshot) => {
                state.isConnected = snapshot.val();
                updateConnectionStatus();
            });
        }

        async function leaveRoom() {
            if (!state.currentRoom) return;

            try {
                const userRef = ref(database, `rooms/${state.currentRoom}/users/${state.userId}`);
                await onDisconnect(userRef).cancel();
                await remove(userRef);
                const roomRef = ref(database, `rooms/${state.currentRoom}`);
                const snapshot = await get(ref(database, `rooms/${state.currentRoom}/users`));
                if (!snapshot.exists()) {
                    await remove(roomRef);
                }

                state.currentRoom = null;
                state.currentPin = null;
                textEditor.value = '';
                typingIndicator.classList.remove('active');

                showJoinScreen();
            } catch (error) {
                console.error('Error leaving room:', error);
            }
        }
        textEditor.addEventListener('input', async (e) => {
            if (!state.currentRoom) return;
            if (state.isApplyingRemoteText) return;

            const text = e.target.value;
            if (state.syncDebounceTimer) {
                clearTimeout(state.syncDebounceTimer);
            }
            state.syncDebounceTimer = setTimeout(async () => {
                try {
                    const textRef = ref(database, `rooms/${state.currentRoom}/text`);
                    await set(textRef, text);
                    state.lastSyncTime = Date.now();
                } catch (error) {
                    console.error('Error syncing text:', error);
                }
            }, 80);
            updateTypingStatus(true);
        });

        async function updateTypingStatus(isTyping) {
            if (!state.currentRoom) return;

            try {
                const userRef = ref(database, `rooms/${state.currentRoom}/users/${state.userId}/isTyping`);
                await set(userRef, isTyping);

                if (isTyping) {
                    if (state.typingTimeout) {
                        clearTimeout(state.typingTimeout);
                    }
                    state.typingTimeout = setTimeout(async () => {
                        try {
                            await set(userRef, false);
                        } catch (error) {
                            console.error('Error updating typing status:', error);
                        }
                    }, 1000);
                }
            } catch (error) {
                console.error('Error updating typing status:', error);
            }
        }
        function showEditorScreen() {
            joinScreen.classList.add('hidden');
            editorScreen.classList.remove('hidden');
            pinDisplay.textContent = state.currentPin;
            updateConnectionStatus();
            updateHeaderVisibility('editor');
        }

        function showJoinScreen() {
            closeFeedbackScreen();
            joinScreen.classList.remove('hidden');
            editorScreen.classList.add('hidden');
            pinInput.value = '';
            pinInput.focus();
            updateHeaderVisibility('join');
        }

        function showFeedbackScreen() {
            feedbackScreen.classList.remove('hidden');
            feedbackInput.focus();
            updateHeaderVisibility('feedback');
        }

        function closeFeedbackScreen() {
            feedbackScreen.classList.add('hidden');
            if (!editorScreen.classList.contains('hidden')) {
                updateHeaderVisibility('editor');
            } else {
                updateHeaderVisibility('join');
            }
        }

        function updateConnectionStatus() {
            if (state.isConnected) {
                statusDot.classList.remove('disconnected');
                statusText.textContent = 'Connected';
            } else {
                statusDot.classList.add('disconnected');
                statusText.textContent = 'Disconnected';
            }
        }
        joinForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const pin = pinInput.value.trim();
            if (pin.length === 6) {
                await joinRoom(pin);
            }
        });

        createBtn.addEventListener('click', createRoom);

        homeBtn.addEventListener('click', leaveRoom);
        leaveBtn.addEventListener('click', leaveRoom);

        infoBtn.addEventListener('click', () => {
            infoPopup.classList.toggle('active');
        });

        document.addEventListener('click', (event) => {
            if (!infoPopup.classList.contains('active')) return;
            if (infoPopup.contains(event.target) || infoBtn.contains(event.target)) return;
            infoPopup.classList.remove('active');
        });

        feedbackBtn.addEventListener('click', () => {
            showFeedbackScreen();
        });

        feedbackHomeBtn.addEventListener('click', closeFeedbackScreen);
        feedbackScreen.addEventListener('click', (e) => {
            if (e.target === feedbackScreen) closeFeedbackScreen();
        });

        function getGoogleLoginErrorMessage(error) {
            const code = error?.code || '';
            const host = window.location.hostname || 'unknown-host';
            if (code === 'auth/unauthorized-domain') {
                return `Google login blocked: unauthorized domain.\nAdd this host in Firebase Auth > Settings > Authorized domains:\n${host}`;
            }
            if (code === 'auth/operation-not-allowed') {
                return 'Google login is disabled. Enable Google provider in Firebase Authentication.';
            }
            if (code === 'auth/popup-blocked') {
                return 'Popup blocked by browser. Allow popups or try again.';
            }
            if (code === 'auth/popup-closed-by-user') {
                return 'Google login popup was closed before completing sign-in.';
            }
            if (code === 'auth/cancelled-popup-request') {
                return 'Login request was cancelled. Please try again.';
            }
            return `Google login failed (${code || 'unknown error'}) on host: ${host}`;
        }

        googleLoginBtn.addEventListener('click', async () => {
            try {
                if (auth.currentUser) {
                    await signOut(auth);
                    return;
                }
                await signInWithPopup(auth, googleProvider);
            } catch (error) {
                console.error('Google login failed:', error);
                const code = error?.code || '';
                if (code === 'auth/popup-blocked' || code === 'auth/cancelled-popup-request') {
                    try {
                        await signInWithRedirect(auth, googleProvider);
                        return;
                    } catch (redirectError) {
                        console.error('Google redirect login failed:', redirectError);
                        alert(getGoogleLoginErrorMessage(redirectError));
                        return;
                    }
                }
                alert(getGoogleLoginErrorMessage(error));
            }
        });

        getRedirectResult(auth).catch((error) => {
            console.error('Google redirect result failed:', error);
            alert(getGoogleLoginErrorMessage(error));
        });

        sendFeedbackBtn.addEventListener('click', async () => {
            const message = feedbackInput.value.trim();
            if (!auth.currentUser) {
                alert('Please login with Google first to send feedback.');
                return;
            }
            if (!message) {
                alert('Please write some feedback before sending.');
                return;
            }
            if (message.length > 1000) {
                alert('Feedback is too long (max 1000 characters).');
                return;
            }
            if (selectedRating < 1 || selectedRating > 5) {
                alert('Please choose a rating by clicking the stars.');
                return;
            }

            try {
                sendFeedbackBtn.disabled = true;
                sendFeedbackBtn.textContent = 'Sending...';

                const ts = Date.now();
                const user = auth.currentUser;
                const feedbackRef = ref(database, `feedbackByUser/${user.uid}`);
                const snapshot = await get(feedbackRef);
                const existing = snapshot.val() || {};

                const data = {
                    uid: user.uid,
                    message: message,
                    createdAt: existing.createdAt || ts,
                    updatedAt: ts,
                    rating: Number(selectedRating),
                    name: user.displayName || 'Google User',
                    email: user.email || '',
                    photoURL: user.photoURL || '',
                };
                if (existing.likesCount) data.likesCount = existing.likesCount;
                if (existing.likedBy) data.likedBy = existing.likedBy;
                if (existing.reply) data.reply = existing.reply;
                if (existing.visitor || state.visitorKey) data.visitor = existing.visitor || state.visitorKey;

                await set(feedbackRef, data);

                sendFeedbackBtn.textContent = 'Update Comment';
                alert('Feedback saved successfully.');
            } catch (error) {
                console.error('Failed to send feedback:', error);
                alert('Could not save feedback. Make sure you are logged in correctly.');
            } finally {
                sendFeedbackBtn.disabled = false;
            }
        });

        deleteFeedbackBtn.addEventListener('click', async () => {
            if (!auth.currentUser) {
                alert('Please login with Google first.');
                return;
            }
            if (!confirm('Delete your feedback and rating?')) return;
            try {
                const myFeedbackRef = ref(database, `feedbackByUser/${auth.currentUser.uid}`);
                await remove(myFeedbackRef);
                feedbackInput.value = '';
                setSelectedRating(0);
                sendFeedbackBtn.textContent = 'Send Comment';
                alert('Your feedback was deleted.');
            } catch (error) {
                console.error('Failed to delete feedback:', error);
                alert('Could not delete feedback. Try again.');
            }
        });

        function renderFeedbackList(items) {
            if (!items.length) {
                feedbackList.innerHTML = `<div class="text-center py-10 text-black/40 text-[13px]">No feedback yet.</div>`;
                return;
            }

            feedbackList.innerHTML = items.map((item) => {
                const isAdmin = isAdminUser(auth.currentUser);
                const byName = item.name || 'Anonymous';
                const byEmail = item.email || '';
                const when = new Date(item.updatedAt || item.createdAt || Date.now()).toLocaleString();
                const editedLabel = item.updatedAt ? '<span class="opacity-30 text-[8px]">(Edited)</span>' : '';
                const starDisplay = '★'.repeat(item.rating || 0).padEnd(5, '☆');
                const likeCount = item.likesCount || 0;
                
                const likerKey = auth.currentUser?.uid || `anon:${state.visitorKey || state.userId}`;
                const isLiked = !!item.likedBy?.[likerKey];
                const likeActiveClasses = isLiked ? 'bg-red-500/20 text-red-600 scale-105' : 'bg-red-500/5 dark:bg-red-500/10 text-red-500';

                const avatar = item.photoURL
                    ? `<img src="${escapeHtml(item.photoURL)}" class="w-11 h-11 rounded-full object-cover border border-black/5 dark:border-white/5 shrink-0">`
                    : `<div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/5 flex items-center justify-center text-[16px] font-black text-black/20 dark:text-white/20 uppercase shrink-0">${(item.name || 'G').charAt(0)}</div>`;

                const replyBlock = item.reply?.text
                    ? `<div class="bg-black/[0.03] dark:bg-white/[0.03] border-l-2 border-brand p-3 rounded-r-xl mt-3 flex flex-col gap-1.5">
                        <div class="text-[9px] font-black uppercase tracking-tight text-brand">Prince Vic Lacson Mayordo</div>
                        <div class="text-[12px] font-medium leading-relaxed text-black/60 dark:text-white/50">${escapeHtml(item.reply.text)}</div>
                    </div>`
                    : '';

                return `
                    <div class="bg-white dark:bg-[#18181b] border border-black/5 dark:border-white/5 rounded-2xl p-4 flex flex-col gap-3.5 transition-all hover:border-black/10 dark:hover:border-white/10 feedback-item" data-feedback-id="${escapeHtml(item.uid || '')}">
                                                <div class="flex items-start justify-between gap-3">
                            <div class="flex items-start gap-3">
                                ${avatar}
                                <div class="flex flex-col gap-0.5 leading-none mt-1">
                                    <div class="text-[12px] font-black text-black dark:text-white uppercase tracking-tight flex items-baseline gap-1.5">
                                        ${escapeHtml(byName)} ${editedLabel}
                                    </div>
                                    <div class="text-[9px] font-medium text-black/40 dark:text-white/30 lowercase tracking-tight">${escapeHtml(byEmail)}</div>
                                    <div class="text-[8.5px] font-medium text-black/30 dark:text-white/20 uppercase tracking-widest mt-0.5">${when}</div>
                                </div>
                            </div>
                            
                                                        <div class="flex flex-col items-end gap-1.5 shrink-0">
                                <div class="text-[10px] text-[#ffc107] font-bold tracking-tight">${starDisplay}</div>
                                <button class="feedback-action-btn ${likeActiveClasses} cursor-pointer flex items-center gap-1.5 py-1 px-2 rounded-full transition-all hover:bg-red-500/20 font-black text-[9px] uppercase active:scale-90" data-action="like">
                                    <svg class="w-2.5 h-2.5 ${isLiked ? 'fill-red-600' : 'fill-current'}" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                    ${likeCount}
                                </button>
                                ${isAdmin ? `<button class="feedback-action-btn bg-surface dark:bg-white/5 border border-black/10 dark:border-white/10 text-[8px] text-black/40 dark:text-white/30 cursor-pointer flex items-center gap-1.5 py-1 px-2 rounded-full transition-all hover:bg-gray-200 dark:hover:bg-white/10 font-bold uppercase tracking-wider" data-action="reply">Reply</button>` : ''}
                            </div>
                        </div>

                                                <div class="text-[13px] font-medium leading-relaxed text-black/80 dark:text-white/70 break-words">${escapeHtml(item.message || '')}</div>
                        
                        <div class="">${replyBlock}</div>
                    </div>
                `;
            }).join('');
        }

        function escapeHtml(text) {
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

        function bindFeedbackList() {
            const feedbackRef = ref(database, 'feedbackByUser');
            onValue(feedbackRef, (snapshot) => {
                const data = snapshot.val() || {};
                feedbackRowsCache = Object.values(data).sort((a, b) => (b.updatedAt || b.createdAt || 0) - (a.updatedAt || a.createdAt || 0));
                renderFeedbackList(feedbackRowsCache);
            });
        }

        async function loadMyFeedback(user) {
            if (!user) {
                feedbackInput.value = '';
                sendFeedbackBtn.textContent = 'Post Feedback';
                setSelectedRating(0);
                deleteFeedbackBtn.style.display = 'none';
                return;
            }

            const myFeedbackRef = ref(database, `feedbackByUser/${user.uid}`);
            const snapshot = await get(myFeedbackRef);
            if (snapshot.exists()) {
                const myFeedback = snapshot.val();
                feedbackInput.value = myFeedback.message || '';
                setSelectedRating(Number(myFeedback.rating) || 0);
                sendFeedbackBtn.textContent = 'Edit Feedback';
                deleteFeedbackBtn.style.display = 'inline-flex';
            } else {
                feedbackInput.value = '';
                setSelectedRating(0);
                sendFeedbackBtn.textContent = 'Post Feedback';
                deleteFeedbackBtn.style.display = 'none';
            }
        }

        function setSelectedRating(value) {
            selectedRating = value;
            starButtons.forEach((btn) => {
                const v = Number(btn.dataset.rating);
                btn.classList.toggle('active', v <= selectedRating);
            });
        }

        ratingRow.addEventListener('click', (event) => {
            const btn = event.target.closest('.star-btn');
            if (!btn) return;
            const value = Number(btn.dataset.rating);
            if (!Number.isNaN(value)) {
                setSelectedRating(value);
            }
        });

        feedbackList.addEventListener('click', async (event) => {
            const actionBtn = event.target.closest('.feedback-action-btn');
            if (!actionBtn) return;
            const itemEl = event.target.closest('.feedback-item');
            if (!itemEl) return;
            const feedbackUid = itemEl.dataset.feedbackId;
            if (!feedbackUid) return;

            const feedbackRef = ref(database, `feedbackByUser/${feedbackUid}`);
            const snapshot = await get(feedbackRef);
            if (!snapshot.exists()) return;
            const current = snapshot.val();

            if (actionBtn.dataset.action === 'like') {
                const likerKey = auth.currentUser?.uid || `anon:${state.visitorKey || state.userId}`;
                const likedBy = current.likedBy || {};
                const isAlreadyLiked = !!likedBy[likerKey];

                const likeRef = ref(database, `feedbackByUser/${feedbackUid}/likedBy/${likerKey}`);
                const countRef = ref(database, `feedbackByUser/${feedbackUid}/likesCount`);

                try {
                    if (isAlreadyLiked) {
                        // UNLIKE: Remove from list and decrement count
                        await remove(likeRef);
                        await runTransaction(countRef, (count) => {
                            return (count || 1) - 1;
                        });
                    } else {
                        // LIKE: Add to list and increment count
                        await set(likeRef, true);
                        await runTransaction(countRef, (count) => {
                            return (count || 0) + 1;
                        });
                    }
                } catch (error) {
                    console.error('Like action failed:', error);
                    alert('You cannot like this yet. Please wait for the database rules to sync.');
                }
                return;
            }

            if (actionBtn.dataset.action === 'reply') {
                if (!isAdminUser(auth.currentUser)) {
                    alert('Only developer admin can reply.');
                    return;
                }
                if (current.reply?.text) return;
                const replyText = prompt('Write one reply:');
                if (!replyText || !replyText.trim()) return;
                const user = auth.currentUser;
                const reply = {
                    text: replyText.trim(),
                    byName: (user?.displayName || user?.email || 'Google user').toString(),
                    byEmail: (user?.email || 'No email').toString(),
                    byUid: user.uid,
                    createdAt: Date.now(),
                };
                await set(feedbackRef, { ...current, reply });
                return;
            }

            if (actionBtn.dataset.action === 'edit-feedback') {
                if (!auth.currentUser || auth.currentUser.uid !== feedbackUid) {
                    alert('You can only edit your own feedback.');
                    return;
                }
                feedbackInput.value = current.message || '';
                setSelectedRating(Number(current.rating) || 0);
                sendFeedbackBtn.textContent = 'Update Comment';
                feedbackInput.focus();
                return;
            }

            if (actionBtn.dataset.action === 'delete-feedback') {
                const canDelete = !!auth.currentUser && (auth.currentUser.uid === feedbackUid || isAdminUser(auth.currentUser));
                if (!canDelete) {
                    alert('Only owner or developer admin can delete this feedback.');
                    return;
                }
                if (!confirm('Delete this feedback?')) return;
                await remove(feedbackRef);
            }
        });

        onAuthStateChanged(auth, (user) => {
            if (user) {
                googleLoginBtn.textContent = 'Logout';
                feedbackAuthUser.style.display = 'inline-flex';
                feedbackAuthUser.innerHTML = `
                    <div class="flex items-center gap-2 pr-2">
                        <img class="w-7 h-7 rounded-full object-cover border border-black/5 dark:border-white/5" src="${escapeHtml(user.photoURL || '')}" alt="">
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[9px] font-black uppercase tracking-tight text-black dark:text-white leading-none">${escapeHtml(user.displayName || 'User')}</span>
                            <span class="text-[8px] font-bold text-black/30 dark:text-white/20 leading-none lowercase">${escapeHtml(user.email || '')}</span>
                        </div>
                    </div>
                `;
                feedbackAuthNote.textContent = '';
                loadMyFeedback(user);
            } else {
                googleLoginBtn.textContent = 'Google Login';
                feedbackAuthUser.style.display = 'none';
                feedbackAuthUser.innerHTML = '';
                feedbackAuthNote.textContent = 'Sign in with Google to participate';
                loadMyFeedback(null);
            }
            renderFeedbackList(feedbackRowsCache);
        });

        copyBtn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(state.currentPin);
                copyBtnText.textContent = 'Copied!';
                copyBtn.classList.add('copied');
                setTimeout(() => {
                    copyBtnText.textContent = 'Copy PIN';
                    copyBtn.classList.remove('copied');
                }, 2000);
            } catch (error) {
                console.error('Failed to copy:', error);
            }
        });
        pinInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                joinForm.dispatchEvent(new Event('submit'));
            }
        });
        document.addEventListener('contextmenu', (e) => e.preventDefault());

        document.addEventListener('keydown', (e) => {
            if (
                e.keyCode === 123 || // F12
                (e.ctrlKey && e.shiftKey && (e.keyCode === 73 || e.keyCode === 74 || e.keyCode === 67)) || // Ctrl+Shift+I/J/C
                (e.ctrlKey && e.keyCode === 85) // Ctrl+U (View Source)
            ) {
                e.preventDefault();
                return false;
            }
        });

        document.addEventListener('dragstart', (e) => e.preventDefault());

        setInterval(() => {
            if (window.outerHeight - window.innerHeight > 200 || window.outerWidth - window.innerWidth > 200) {
                console.clear();
                console.log("%cSTOP!", "color: red; font-family: sans-serif; font-size: 4em; font-weight: bolder; text-shadow: #000 1px 1px;");
                console.log("%cThis is a browser feature intended for developers. If someone told you to copy-paste something here, it is a scam.", "font-size: 1.5em;");
            }
        }, 1000);

        trackTotalUsers();
        trackActiveToday();
        bindFeedbackList();
        initializeVisitorKey().then(setupWebsitePresence);
        pinInput.focus();
    </script>
</body>

</html>
